rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Admin';
    }

    function isDeliveryPartner() {
      return isAuthenticated() && getUserRole() == 'DeliveryPartner';
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Menu Items ─────────────────────────────────────────────────────────
    match /menuItems/{itemId} {
      allow read: if true; // Public — anyone can browse the menu
      allow write: if isAdmin();
    }

    // ─── Categories ─────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Orders ─────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin() || isDeliveryPartner()
      );
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isDeliveryPartner();
      allow delete: if isAdmin();
    }

    // ─── Reviews ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ─── Coupons ────────────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if isAuthenticated(); // logged-in users can read/validate
      allow write: if isAdmin();
    }

    // ─── Notifications ───────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAdmin();
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ─── Delivery Partners ───────────────────────────────────────────────────
    match /deliveryPartners/{partnerId} {
      allow read: if isAdmin() || isDeliveryPartner();
      allow write: if isAdmin();
    }

    // ─── Analytics ───────────────────────────────────────────────────────────
    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── Banners ────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Offers ─────────────────────────────────────────────────────────────
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
